---
import Page from '../layouts/Page.astro';
import { CONTACT_URL } from '../config/contact';
---

<Page title="Mobile Photo Studio" description="Editorial, portrait, and lifestyle photography by Emily Rose Doud — warm, botanical, and intentional.">

  <!-- Hero -->
  <section class="section-padded pb-section-sm">
    <div class="container-content">
      <div class="flex flex-col sm:flex-row sm:items-center gap-6 mb-6">
        <img
          src="/images/photography-logo.jpg"
          alt="Mobile Photo Studio logo"
          class="w-24 h-24 object-contain rounded-xl"
        />
        <div>
          <p class="text-label mb-2 reveal">Creative Work</p>
          <h1 class="font-display text-display-lg text-brown reveal reveal-delay-1">Mobile Photo Studio</h1>
        </div>
      </div>
      <p class="text-body-lg max-w-2xl reveal reveal-delay-2">
        Editorial, portrait, and lifestyle photography. My work has a warm, botanical quality —
        natural light, honest moments, intentional composition.
      </p>
    </div>
  </section>

  <!-- Portrait section -->
  <section class="section-padded">
    <div class="container-content">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 lg:gap-16 items-start">
        <div>
          <div class="flex flex-wrap gap-2 mb-8 reveal">
            <span class="tag-sage">Portrait</span>
            <span class="tag-sage">Editorial</span>
            <span class="tag-sage">Lifestyle</span>
            <span class="tag-sage">Product</span>
          </div>
          <p class="text-body-lg mb-4 reveal reveal-delay-1">
            Every session starts with a conversation. I want to understand what you're trying to
            say before I pick up a camera — whether that's a brand shoot, a portrait session, or
            editorial work.
          </p>
          <p class="text-body reveal reveal-delay-2">
            Portfolio images coming soon — reach out to see current work.
          </p>
        </div>

        <!-- Portrait photo grid -->
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-3 reveal reveal-delay-1">
          <div class="col-span-2 aspect-[3/2] rounded-xl overflow-hidden">
            <img src="/images/photography/marley-1.jpg" alt="Portrait — Marley" class="w-full h-full object-cover" />
          </div>
          <div class="aspect-square rounded-xl overflow-hidden">
            <img src="/images/photography/marley-2.jpg" alt="Portrait — Marley" class="w-full h-full object-cover" />
          </div>
          <div class="aspect-square rounded-xl overflow-hidden">
            <img src="/images/photography/claire-1.jpg" alt="Portrait — Claire" class="w-full h-full object-cover" />
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Pricing -->
  <section class="section-padded bg-cream-50 border-y border-cream-200">
    <div class="container-content">
      <h2 class="font-display text-display-md text-brown ruled-heading mb-6 reveal">Pricing</h2>
      <p class="text-body-lg max-w-xl reveal reveal-delay-1">
        Pricing varies based on the type of session, location, and deliverables.
        Reach out and we'll find something that works for you.
      </p>
      <a
        target="_blank"
        rel="noopener noreferrer"
        href={CONTACT_URL}
        class="btn-primary mt-8 inline-flex reveal reveal-delay-2"
      >
        Email for Pricing →
      </a>
    </div>
  </section>

  <!-- CTA -->
  <section class="section-padded">
    <div class="container-content text-center">
      <h2 class="font-display text-display-md text-brown mb-6 reveal">Book a Session</h2>
      <p class="text-body-lg max-w-md mx-auto mb-8 reveal reveal-delay-1">
        Ready to work together? Let's talk about availability and creative vision.
      </p>
      <a target="_blank" rel="noopener noreferrer" href={CONTACT_URL} class="btn-primary reveal reveal-delay-2">
        Get in Touch →
      </a>
    </div>
  </section>

</Page>
