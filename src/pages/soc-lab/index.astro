---
import Page from '../../layouts/Page.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('soc-lab', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<Page title="SOC Lab" description="Home lab security writeups — SIEM analysis, incident detection, and threat hunting by Emily Rose Doud.">

  <section class="section-padded pb-0">
    <div class="container-content">
      <p class="text-label mb-4 reveal">Security Practice</p>
      <h1 class="font-display text-display-lg text-brown mb-6 reveal reveal-delay-1">SOC Lab</h1>
      <p class="text-body-lg max-w-2xl reveal reveal-delay-2">
        My home SOC lab is in progress — this is where I'll document simulations, log analysis,
        and detection work as I build out the environment. Check back soon for the first writeup.
      </p>
    </div>
  </section>

  <!-- Scenario -->
  <section class="section-padded pb-0">
    <div class="container-content">
      <div class="card p-6 sm:p-10 max-w-3xl reveal">
        <p class="text-label mb-4">Simulated Environment</p>
        <h2 class="font-serif text-2xl text-brown mb-6">The Scenario</h2>
        <p class="text-body-lg mb-4">
          Doud Co. is a six-person operation with a tight-knit team: Leonardo and Raphael anchor
          Human Resources, April O'Neil manages Finance, Donatello serves as both IT administrator
          and the company's reluctant one-man security team, and Casey Jones and Michelangelo round
          out Sales. Small but capable — on paper.
        </p>
        <p class="text-body mb-4">
          In practice, Donatello has his hands full. Despite the team's talent and enthusiasm, their
          devices are anything but secure. Brute force attempts and DDoS traffic have become a
          recurring headache, and Donatello can't shake the feeling that someone on the inside is
          making it worse — whether through careless habits, weak credentials, or something worse.
        </p>
        <p class="text-body">
          The question isn't whether Doud Co. has a security problem. It's <em>which employee</em> is
          leaving the door open — and how to prove it.
        </p>
      </div>
    </div>
  </section>

  <section class="section-padded">
    <div class="container-content">
      {posts.length === 0 ? (
        <div class="card p-12 text-center">
          <p class="font-serif text-2xl text-brown/40 italic">Coming Soon.</p>
          <p class="text-body mt-2">First writeup in progress — check back shortly.</p>
        </div>
      ) : (
        <div class="grid gap-6">
          {posts.map((post, i) => (
            <a
              href={`/soc-lab/${post.slug}`}
              class={`card p-8 group grid sm:grid-cols-[1fr_auto] gap-4 reveal reveal-delay-${Math.min(i + 1, 4)}`}
            >
              <div>
                <div class="flex flex-wrap gap-2 mb-3">
                  {post.data.tags.map(tag => <span class="tag-rose">{tag}</span>)}
                </div>
                <h2 class="font-serif text-2xl text-brown group-hover:text-rose-deep transition-colors mb-2">
                  {post.data.title}
                </h2>
                <p class="text-body">{post.data.description}</p>
              </div>
              <time class="text-label self-start whitespace-nowrap" datetime={post.data.date.toISOString()}>
                {post.data.date.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}
              </time>
            </a>
          ))}
        </div>
      )}
    </div>
  </section>

</Page>
