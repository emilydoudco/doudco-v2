---
import Page from '../../layouts/Page.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const studies = await getCollection('case-studies', ({ data }) => !data.draft);
  return studies.map(study => ({
    params: { slug: study.slug },
    props:  { study },
  }));
}

const { study } = Astro.props;
const { Content } = await study.render();
---

<Page title={study.data.title} description={study.data.description}>

  <section class="section-padded pb-0">
    <div class="container-content max-w-3xl">
      <a href="/case-studies" class="text-label inline-flex items-center gap-2 mb-6 hover:text-rose-deep transition-colors reveal">
        ← Case Studies
      </a>
      <div class="flex flex-wrap gap-2 mb-4 reveal reveal-delay-1">
        {study.data.tags.map(tag => <span class="tag-rose">{tag}</span>)}
      </div>
      <h1 class="font-display text-display-md text-brown mb-4 reveal reveal-delay-1">
        {study.data.title}
      </h1>
      {study.data.outcome && (
        <div class="tag-sage text-sm mb-4 reveal reveal-delay-2">
          Outcome: {study.data.outcome}
        </div>
      )}
      <div class="flex items-center gap-4 reveal reveal-delay-2">
        <time class="text-label" datetime={study.data.date.toISOString()}>
          {study.data.date.toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' })}
        </time>
        {study.data.client && (
          <>
            <span class="text-brown-light/40">·</span>
            <span class="text-label">{study.data.client}</span>
          </>
        )}
      </div>
    </div>
  </section>

  <article class="section-padded prose-doudco">
    <div class="container-content max-w-3xl reveal reveal-delay-1">
      <Content />
    </div>
  </article>

  <div class="section-padded pt-0">
    <div class="container-content max-w-3xl border-t border-cream-200 pt-8">
      <a href="/case-studies" class="btn-ghost">← All Case Studies</a>
    </div>
  </div>

</Page>

<style is:global>
  .prose-doudco h2 { @apply font-display text-display-md text-brown mt-12 mb-4 relative pb-4; }
  .prose-doudco h2::after { content: ''; @apply absolute bottom-0 left-0 w-12 h-0.5 bg-rose-deep; }
  .prose-doudco h3 { @apply font-serif text-2xl text-brown mt-8 mb-3; }
  .prose-doudco p  { @apply text-body mb-4; }
  .prose-doudco ul, .prose-doudco ol { @apply pl-6 mb-4 space-y-2; }
  .prose-doudco li { @apply text-body; }
  .prose-doudco ul li { @apply list-disc; }
  .prose-doudco ol li { @apply list-decimal; }
  .prose-doudco a { @apply text-rose-deep underline decoration-rose-light underline-offset-2 hover:text-rose-mid transition-colors; }
  .prose-doudco strong { @apply font-medium text-brown; }
  .prose-doudco em { @apply italic text-brown-mid; }
  .prose-doudco code:not(pre code) { @apply font-mono text-sm bg-cream-200 text-rose-deep px-1.5 py-0.5 rounded; }
  .prose-doudco pre { @apply rounded-xl bg-brown-deep text-cream-50 p-6 overflow-x-auto mb-6 text-sm font-mono leading-relaxed; }
  .prose-doudco blockquote { @apply border-l-4 border-rose-deep pl-6 italic text-brown-mid my-6; }
</style>
