---
import Page from '../layouts/Page.astro';
import { CONTACT_URL } from '../config/contact';
---

<Page title="Graphic Design" description="Brand identity, print, and digital design by Emily Rose Doud — intentional, precise, and considered.">

  <section class="section-padded pb-section-sm">
    <div class="container-content">
      <p class="text-label mb-4 reveal">Creative Work</p>
      <h1 class="font-display text-display-lg text-brown mb-6 reveal reveal-delay-1">Graphic Design</h1>
      <p class="text-body-lg max-w-2xl reveal reveal-delay-2">
        Brand identity, print, and digital design. I bring the same careful eye I use behind
        the lens to every layout and logo.
      </p>
    </div>
  </section>

  <section class="section-padded">
    <div class="container-content">
      <div class="grid lg:grid-cols-2 gap-16 items-start">
        <div>
          <div class="flex flex-wrap gap-2 mb-8 reveal">
            <span class="tag-sage">Branding</span>
            <span class="tag-sage">Print</span>
            <span class="tag-sage">Digital</span>
            <span class="tag-sage">Typography</span>
          </div>
          <p class="text-body-lg mb-4 reveal reveal-delay-1">
            Good design solves a problem and looks good doing it. I work from identity systems to
            one-off print pieces — always starting with what the work needs to communicate, then
            building from there.
          </p>
          <p class="text-body reveal reveal-delay-2">
            Portfolio images coming soon — reach out to see current work.
          </p>
        </div>

        <!-- Design work grid placeholder -->
        <div class="grid grid-cols-2 gap-3 reveal reveal-delay-1">
          <div class="col-span-2 aspect-[2/1] rounded-xl bg-gradient-to-br from-cream-200 to-rose-pale flex items-center justify-center">
            <span class="text-brown/20 text-xs font-mono">coming soon</span>
          </div>
          <div class="aspect-square rounded-xl bg-gradient-to-br from-rose-pale to-sage-pale flex items-center justify-center">
            <span class="text-brown/20 text-xs font-mono">coming soon</span>
          </div>
          <div class="aspect-square rounded-xl bg-gradient-to-br from-sage-pale to-cream-200 flex items-center justify-center">
            <span class="text-brown/20 text-xs font-mono">coming soon</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section-padded bg-cream-50 border-t border-cream-200">
    <div class="container-content text-center">
      <h2 class="font-display text-display-md text-brown mb-6 reveal">Start a Project</h2>
      <p class="text-body-lg max-w-md mx-auto mb-8 reveal reveal-delay-1">
        Have a brand, print piece, or digital project in mind? Let's talk about what you need.
      </p>
      <a target="_blank" rel="noopener noreferrer" href={CONTACT_URL} class="btn-primary reveal reveal-delay-2">
        Get in Touch →
      </a>
    </div>
  </section>

</Page>
