---
import Page from '../layouts/Page.astro';

const stats = [
  { number: '12+',   label: 'Machines Refurbished' },
  { number: '4',     label: 'Organizations Served' },
  { number: '100%',  label: 'Free to Recipients' },
];

const process = [
  { step: '01', title: 'Collection',   desc: 'Hardware donated by individuals and local businesses.' },
  { step: '02', title: 'Assessment',   desc: 'Each machine is tested for functionality and repairability.' },
  { step: '03', title: 'Rebuild',      desc: 'Full wipe, fresh OS install (usually Ubuntu or Windows 10 LTSC), drivers, and security hardening.' },
  { step: '04', title: 'Delivery',     desc: 'Delivered to shelters, community centers, and nonprofits with basic tech orientation.' },
];
---

<Page
  title="Operation Closet Computer"
  description="Refurbishing donated computers and delivering them to shelters and community organizations in need."
>

  <!-- Hero -->
  <section class="section-padded pb-section-sm">
    <div class="container-content">
      <p class="text-label mb-4 reveal">Community Project</p>
      <h1 class="font-display text-display-lg text-brown mb-6 reveal reveal-delay-1">
        Operation<br /><em class="not-italic text-rose-deep">Closet Computer</em>
      </h1>
      <p class="text-body-lg max-w-2xl reveal reveal-delay-2">
        A closet full of forgotten hardware. Communities without access to technology.
        One mission: close the gap between the two.
      </p>
    </div>
  </section>

  <!-- Stats -->
  <section class="border-y border-cream-200 bg-cream-50">
    <div class="section-padded py-16">
      <div class="container-content grid grid-cols-3 gap-8 text-center">
        {stats.map((stat, i) => (
          <div class={`reveal reveal-delay-${i + 1}`}>
            <p class="font-display text-5xl text-rose-deep mb-2">{stat.number}</p>
            <p class="text-label">{stat.label}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- The Mission -->
  <section class="section-padded">
    <div class="container-content grid lg:grid-cols-2 gap-16">
      <div>
        <h2 class="font-display text-display-md text-brown ruled-heading mb-8 reveal">The Mission</h2>
        <p class="text-body-lg mb-4 reveal reveal-delay-1">
          Access to a working computer shouldn't be a privilege. For people experiencing
          houselessness, job seekers at shelters, and students without devices, a refurbished
          machine can change the trajectory of their lives.
        </p>
        <p class="text-body reveal reveal-delay-2">
          Operation Closet Computer started when I realized I had more spare hardware than I
          could use — and that people nearby had none at all. The fix was obvious.
        </p>
      </div>

      <!-- Process -->
      <div>
        <h2 class="font-display text-display-md text-brown ruled-heading mb-8 reveal">The Process</h2>
        <div class="space-y-6">
          {process.map((step, i) => (
            <div class={`flex gap-4 reveal reveal-delay-${i + 1}`}>
              <span class="font-mono text-sm text-rose-deep font-medium w-8 shrink-0 pt-1">{step.step}</span>
              <div>
                <h3 class="font-serif text-lg text-brown mb-1">{step.title}</h3>
                <p class="text-body text-sm">{step.desc}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- Donate CTA -->
  <section class="section-padded bg-gradient-to-br from-sage-pale/30 to-cream">
    <div class="container-content text-center">
      <h2 class="font-display text-display-md text-brown mb-6 reveal">Want to Donate Hardware?</h2>
      <p class="text-body-lg max-w-lg mx-auto mb-8 reveal reveal-delay-1">
        Old laptops, desktops, and accessories welcome. If it can run a browser and a
        word processor, it can change someone's week.
      </p>
      <a href="mailto:hello@doudco.com?subject=Hardware Donation" class="btn-primary reveal reveal-delay-2">
        Get in Touch →
      </a>
    </div>
  </section>

</Page>
